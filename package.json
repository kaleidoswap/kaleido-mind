    "lint": "pnpm -r run lint",
    "play": "pnpm --filter @kaleido/mind-playground run start"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@qvac/sdk": "^0.12.0",
    "require-asset": "^1.2.2"
  }
}
