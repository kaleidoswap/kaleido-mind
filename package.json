{
  "name": "kaleido-mind",
  "version": "0.0.1",
  "private": true,
  "description": "Sovereign AI for sovereign money. Local-first reasoning + function-calling engine for KaleidoSwap.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
