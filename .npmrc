# Use a flat (npm-style) node_modules layout.
#
# The QVAC / bare-kit native toolchain (bare-pack, bare-link, the bare-kit
# ios/android link.mjs) assumes a flat node_modules: it resolves the project
# root as <pkg>/../../.. and resolves sibling addon packages by walking up
# node_modules. pnpm's default symlinked .pnpm layout breaks all of this —
# the project root resolves inside .pnpm and the native addons (llamacpp,
# whispercpp, bare-runtime-darwin-arm64, …) never get linked correctly,
# causing `Error: No binaries found for target 'darwin-arm64'` and similar
# crashes the moment loadModel() spawns its Bare subprocess.
#
# Same setting as rate/.npmrc — keep them in sync.
node-linker=hoisted

# Bare's platform-specific runtime packages depend on `require-asset`, which
# pnpm leaves nested by default — bare-runtime-darwin-arm64/index.js then
# fails to resolve it, and bare-runtime turns the MODULE_NOT_FOUND into a
# misleading "No binaries found for target 'darwin-arm64'" error.
# Hoisting everything fixes it.
shamefully-hoist=true
