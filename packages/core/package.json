{
  "name": "@kaleidorg/mind",
  "version": "0.3.0",
  "description": "Local-first reasoning + function-calling engine for KaleidoSwap. QVAC-powered.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaleidoswap/kaleido-mind.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/tools/mcp.d.ts",
      "import": "./dist/tools/mcp.js",
      "default": "./dist/tools/mcp.js"
    },
    "./skills": {
      "types": "./dist/skills/loader.d.ts",
      "import": "./dist/skills/loader.js",
      "default": "./dist/skills/loader.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js",
      "default": "./dist/logger.js"
    }
  },
  "files": [
    "dist",
    "src",
    "skills",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "bundle-skills": "node scripts/bundle-skills.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  }
}
