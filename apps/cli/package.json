{
  "name": "@kaleidorg/mind-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive terminal harness for @kaleidorg/mind — run the full agent (QVAC + skills + memory + RAG + tools) on your Mac to test before mobile/desktop.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "kaleido-mind": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/index.ts eval",
    "eval:all": "bash run-eval.sh",
    "serve": "tsx src/index.ts serve"
  },
  "dependencies": {
    "@kaleidorg/mind": "workspace:*"
  },
  "peerDependencies": {
    "@qvac/sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
